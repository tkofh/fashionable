{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "useTabs": false,
  "tabWidth": 2,
  "printWidth": 100,
  "singleQuote": true,
  "jsxSingleQuote": false,
  "quoteProps": "as-needed",
  "trailingComma": "all",
  "semi": false,
  "arrowParens": "always",
  "bracketSameLine": false,
  "bracketSpacing": true,
  "ignorePatterns": [],
  "sortImports": {
    "newlinesBetween": false,
    "customGroups": [
      {
        "elementNamePattern": ["@repo/**"],
        "groupName": "repo"
      }
    ],
    "groups": [
      ["builtin", "external"],
      "repo",
      ["internal", "subpath"],
      "parent",
      "sibling",
      "index",
      "unknown"
    ]
  }
}
