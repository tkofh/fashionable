{
  "name": "fashionable",
  "version": "0.1.0",
  "description": "Structural stylesheet modeling and calc expression evaluation",
  "homepage": "https://github.com/tkofh/fashionable#readme",
  "bugs": {
    "url": "https://github.com/tkofh/fashionable/issues"
  },
  "license": "MIT",
  "author": "Tim Morris <timthewebguy@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tkofh/fashionable.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "imports": {
    "#util": "./src/utils.ts",
    "#calc": "./src/calc/index.ts",
    "#calc/*": "./src/calc/*.ts",
    "#data": "./src/data/index.ts",
    "#data/*": "./src/data/*.ts",
    "#declaration": "./src/declaration/index.ts",
    "#declaration/*": "./src/declaration/*.ts",
    "#fontFace": "./src/fontFace/index.ts",
    "#fontFace/*": "./src/fontFace/*.ts",
    "#internal/*": "./src/internal/*.ts",
    "#property": "./src/property/index.ts",
    "#property/*": "./src/property/*.ts",
    "#query": "./src/query/index.ts",
    "#query/*": "./src/query/*.ts",
    "#rule": "./src/rule/index.ts",
    "#rule/*": "./src/rule/*.ts",
    "#selector": "./src/selector/index.ts",
    "#selector/*": "./src/selector/*.ts",
    "#stylesheet": "./src/stylesheet/index.ts",
    "#stylesheet/*": "./src/stylesheet/*.ts"
  },
  "exports": {
    "./calc": {
      "types": "./dist/calc/index.d.mts",
      "import": "./dist/calc/index.mjs"
    },
    "./data": {
      "types": "./dist/data/index.d.mts",
      "import": "./dist/data/index.mjs"
    },
    "./declaration": {
      "types": "./dist/declaration/index.d.mts",
      "import": "./dist/declaration/index.mjs"
    },
    "./font-face": {
      "types": "./dist/fontFace/index.d.mts",
      "import": "./dist/fontFace/index.mjs"
    },
    "./property": {
      "types": "./dist/property/index.d.mts",
      "import": "./dist/property/index.mjs"
    },
    "./query": {
      "types": "./dist/query/index.d.mts",
      "import": "./dist/query/index.mjs"
    },
    "./rule": {
      "types": "./dist/rule/index.d.mts",
      "import": "./dist/rule/index.mjs"
    },
    "./selector": {
      "types": "./dist/selector/index.d.mts",
      "import": "./dist/selector/index.mjs"
    },
    "./stylesheet": {
      "types": "./dist/stylesheet/index.d.mts",
      "import": "./dist/stylesheet/index.mjs"
    },
    "./utils": {
      "types": "./dist/utils.d.mts",
      "import": "./dist/utils.mjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "build:watch": "tsdown --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "tsdown": "^0.22.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
